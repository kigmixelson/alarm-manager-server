[Unit]
Description=Alarm Manager worker (poll API, print groups)
After=network-online.target alarm-manager-server.service
Wants=network-online.target
Requires=alarm-manager-server.service

[Service]
Type=simple
User=alarm
Group=alarm
WorkingDirectory=/opt/alarm-manager-server
EnvironmentFile=/opt/alarm-manager-server/.env
ExecStart=/opt/alarm-manager-server/.venv/bin/alarm-manager-worker --responsible
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
