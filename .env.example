# SAYMON API
SAYMON_BASE_URL=http://localhost:8080
SAYMON_API_PREFIX=/node/api
SAYMON_LOGIN=
SAYMON_PASSWORD=
# После логина — GET с cookies (как ?url= в /apps/auth); пусто = пропустить
SAYMON_AUTH_REDIRECT_URL=

# Grouping (mirrors frontend defaults)
GROUP_BY_CLASS_NAMES=["Host","Router","Local Address"]
GROUP_BY_DEPTH=4

# Responsible-party macros
MACROS=["{{parent[class.id=30,3,24].properties[17. Ответственный]}}","{{parent[class.id=30,3,24].properties[20. Группа для уведомления администраторов систем]}}"]
MACRO_DEPTH=8

# Fetch limits (paginated; raise if web UI shows more incidents than worker)
FETCH_LIMIT=1000
HISTORY_LIMIT=5000
FETCH_PAGE_SIZE=500

# Background worker (alarm-manager-worker)
# В docker compose worker использует http://server:4800 автоматически
SERVER_URL=http://127.0.0.1:4800
WORKER_INTERVAL_SEC=60
INCIDENT_LINK_TEMPLATE={saymon_base_url}/saymon.local/apps/alarm-manager?incident={id}

# File cache (persists between container restarts; mount CACHE_DIR as a volume in Docker)
CACHE_ENABLED=true
CACHE_DIR=/var/cache/alarm-manager
# TTL in seconds per data type (0 = never read from cache for that type)
CACHE_TTL_INCIDENTS_SEC=120
CACHE_TTL_OBJECTS_SEC=3600
CACHE_TTL_OBJECT_PATHS_SEC=3600
CACHE_TTL_STATE_LABELS_SEC=86400
CACHE_TTL_CLASS_IDS_SEC=86400

# Worker tickets (between runs: create / update / close groups)
TICKETS_FILE=/var/lib/alarm-manager/tickets.json
# Handlers внешней тикет-системы (module:Class, через запятую; нужен --tickets)
# TICKET_HANDLERS=alarm_manager_server.worker.ticket_handlers:LoggingTicketHandler
# TICKET_HANDLERS=my_company.integrations:ServiceDeskHandler
